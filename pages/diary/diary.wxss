/* pages/diary/diary.wxss */

.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
  display: block;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.btn-go {
  background: #4CAF50;
  border-radius: 60rpx;
  padding: 20rpx 60rpx;
}

.btn-go-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
}

/* List Header */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx 16rpx;
}

.list-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
}

.list-count {
  font-size: 24rpx;
  color: #aaaaaa;
}

/* Record List */
.record-list {
  padding: 8rpx 20rpx 0;
}

.record-row {
  display: flex;
  margin-bottom: 0;
}

/* Timeline */
.timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 12rpx;
  margin-right: 20rpx;
  width: 24rpx;
}

.tl-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  background: #4CAF50;
  flex-shrink: 0;
}

.tl-dot-warn {
  background: #FF9800;
}

.tl-line {
  width: 4rpx;
  flex: 1;
  min-height: 40rpx;
  background: #e0e0e0;
  margin: 8rpx 0;
}

/* Card */
.record-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.date-group {
  display: flex;
  align-items: center;
}

.record-date {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  margin-right: 12rpx;
}

.record-weekday {
  font-size: 22rpx;
  color: #aaaaaa;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.card-actions {
  display: flex;
}

.action-btn {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
}

.action-edit {
  color: #4CAF50;
  margin-right: 8rpx;
}

.action-delete {
  color: #ef5350;
}

/* Note */
.record-note {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.note-placeholder {
  color: #cccccc;
  font-style: italic;
}

/* Interval Tag */
.interval-tag {
  display: inline-block;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  margin-top: 4rpx;
}

.tag-normal {
  background: #E8F5E9;
}

.tag-warn {
  background: #FFF3E0;
}

.interval-text {
  font-size: 22rpx;
}

.tag-normal .interval-text {
  color: #4CAF50;
}

.tag-warn .interval-text {
  color: #FF9800;
}

/* Modal */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal {
  background: #ffffff;
  border-radius: 24rpx;
  width: 640rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  display: block;
}

.modal-sub {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-top: 6rpx;
  display: block;
}

.modal-close {
  padding: 8rpx 12rpx;
}

.close-icon {
  font-size: 32rpx;
  color: #aaaaaa;
}

.modal-body {
  padding: 32rpx;
}

.note-textarea {
  width: 100%;
  min-height: 180rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.7;
}

.modal-btns {
  display: flex;
  margin-top: 24rpx;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  margin-right: 16rpx;
  font-size: 30rpx;
  color: #666;
}

.btn-save {
  flex: 1;
  background: #4CAF50;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
}
