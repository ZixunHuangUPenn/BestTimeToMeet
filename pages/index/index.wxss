/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
}

/* Stats Bar */
.stats-bar {
  display: flex;
  background: #4CAF50;
  padding: 32rpx 20rpx;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* Calendar Card */
.calendar-card {
  background: #ffffff;
  margin: 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 20rpx 16rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* Month Navigation */
.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 10rpx 24rpx;
}

.nav-btn {
  padding: 10rpx 24rpx;
}

.nav-arrow {
  font-size: 52rpx;
  color: #4CAF50;
  line-height: 1;
}

.month-label {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
}

/* Weekday Row */
.weekday-row {
  display: flex;
  margin-bottom: 8rpx;
}

.weekday-cell {
  width: 14.2857%;
  text-align: center;
  font-size: 24rpx;
  color: #aaaaaa;
  padding: 8rpx 0;
}

.weekday-cell.weekend {
  color: #ef5350;
}

/* Days Grid */
.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: 14.2857%;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.day-inner {
  width: 62rpx;
  height: 62rpx;
  border-radius: 31rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.is-today {
  background: #4CAF50;
}

.day-num {
  font-size: 28rpx;
  color: #333;
}

.num-today {
  color: #ffffff;
  font-weight: bold;
}

.num-record {
  color: #4CAF50;
  font-weight: bold;
}

.num-today-record {
  color: #ffffff;
  font-weight: bold;
}

/* Wash Dot */
.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #4CAF50;
  margin-top: 2rpx;
}

.dot-white {
  background: #ffffff;
}

.dot-invis {
  background: transparent;
}

/* FAB Button */
.fab {
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #4CAF50;
  padding: 22rpx 60rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.45);
}

.fab-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  white-space: nowrap;
}

/* Modal Overlay */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal {
  background: #ffffff;
  border-radius: 24rpx;
  width: 640rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}

.modal-close {
  padding: 8rpx 12rpx;
}

.close-icon {
  font-size: 32rpx;
  color: #aaaaaa;
}

.modal-body {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.recorded-badge {
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.recorded-text {
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: bold;
}

.modal-note {
  font-size: 26rpx;
  color: #555;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.note-empty {
  color: #bbbbbb;
  font-style: italic;
}

.modal-hint {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 24rpx;
}

.note-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  min-height: 80rpx;
}

.btn-add {
  background: #4CAF50;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 22rpx;
  text-align: center;
}

.btn-delete {
  background: #ffffff;
  color: #F44336;
  border: 2rpx solid #F44336;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 18rpx;
  text-align: center;
}
